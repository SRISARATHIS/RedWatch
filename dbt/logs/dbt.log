  ) AS kpi_key,

  minute_ts,
  instance_id,
  workload_classification,
  access_scope,
  query_type,

  queries_count,
  heavy_units_sum,

  scanned_mb_sum,
  spilled_mb_sum,

  exec_ms_sum,
  queue_ms_sum,

  cluster_size_clean_max,
  source_max_raw_id

FROM agg
  );
  
  
