  create temporary table "kpi_minute_shadow_cost__dbt_tmp104132138941"
  
  
    as
  
  (
    

WITH bounds AS (

  
    SELECT COALESCE(MAX(minute_ts), TIMESTAMP '1970-01-01') AS max_minute_ts
    FROM "redset_db"."analytics_analytics"."kpi_minute_shadow_cost"
  

