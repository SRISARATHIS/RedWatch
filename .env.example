# =========================
# Postgres (core database)
# =========================
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Used by Python services / Streamlit if needed
PG_DSN=postgresql://redset:redset@postgres:5432/redset_db


# =========================
# Kafka
# =========================
KAFKA_BOOTSTRAP_SERVERS=broker:9092
KAFKA_TOPIC=REDSET


# =========================
# Raw + Clean tables
# =========================
PG_RAW_TABLE=public.redset_events
CLEAN_TABLE=analytics.clean_table


# =========================
# dbt configuration
# =========================
DBT_SCHEMA=analytics
DBT_RUN_SECONDS=20


# =========================
# Loader / Cleaner
# =========================
PG_STATE_TABLE=cleaner_state
CLEANER_NAME=cleaner_v1
BATCH_SIZE=5000
POLL_SECONDS=2


# =========================
# KPI execution control
# =========================
MIN_ROWS=1000        # minimum clean_table rows before KPIs are meaningful
SLEEP_SECONDS=30     # KPI refresh cadence (seconds)
